<% layout("/layouts/boilerplate.ejs") %>

<!-- NestAway — New Listing Form (views/listings/new.ejs) -->
<!-- Also usable as the base for edit.ejs — see bottom note -->

<div class="container" style="padding:3rem 1rem 5rem;">
  <div style="max-width:640px;margin:0 auto;">

    <!-- Page header -->
    <div class="reveal" style="margin-bottom:2rem;">
      <a href="/listings" style="color:var(--text-muted);font-size:0.85rem;text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;margin-bottom:1.2rem;">
        <i class="bi bi-arrow-left"></i> Back to listings
      </a>
      <p class="section-label">Host on NestAway</p>
      <h1 class="page-title">Add a New Listing</h1>
      <p style="color:var(--text-muted);font-size:0.9rem;">Share your space with travellers from around the world.</p>
    </div>

    <div class="form-wrapper reveal" style="max-width:100%;">
      <form method="POST" action="/listings" enctype="multipart/form-data" novalidate>

        <!-- Title -->
        <div class="mb-4">
          <label class="form-label" for="title">
            <i class="bi bi-house me-1"></i>Property Title
          </label>
          <input type="text" class="form-control" id="title" name="listing[title]"
                 placeholder="e.g. Cosy Beach Villa in Goa" required>
        </div>

        <!-- Description -->
        <div class="mb-4">
          <label class="form-label" for="description">
            <i class="bi bi-card-text me-1"></i>Description
          </label>
          <textarea class="form-control" id="description" name="listing[description]"
                    rows="4" placeholder="Describe what makes your place special…"></textarea>
        </div>

        <!-- Image Upload -->
        <div class="mb-4">
          <label class="form-label" for="image">
            <i class="bi bi-image me-1"></i>Property Image
          </label>
          <input type="file" class="form-control" id="image" name="listing[image]"
                 accept="image/*" onchange="previewImage(this)">
          <div id="imgPreview" style="display:none;margin-top:0.75rem;">
            <img id="previewEl" src="" alt="Preview"
                 style="width:100%;height:200px;object-fit:cover;border-radius:var(--radius-md);border:1px solid var(--border);">
          </div>
        </div>

        <!-- Price -->
        <div class="mb-4">
          <label class="form-label" for="price">
            <i class="bi bi-currency-rupee me-1"></i>Price per Night (₹)
          </label>
          <input type="number" class="form-control" id="price" name="listing[price]"
                 placeholder="e.g. 3500" min="0" required>
        </div>

        <!-- Location & Country (2 cols) -->
        <div class="row g-3 mb-4">
          <div class="col-md-7">
            <label class="form-label" for="location">
              <i class="bi bi-geo-alt me-1"></i>City / Location
            </label>
            <input type="text" class="form-control" id="location" name="listing[location]"
                   placeholder="e.g. Goa, Jaipur, Manali" required>
          </div>
          <div class="col-md-5">
            <label class="form-label" for="country">
              <i class="bi bi-globe me-1"></i>Country
            </label>
            <input type="text" class="form-control" id="country" name="listing[country]"
                   placeholder="e.g. India" required>
          </div>
        </div>

        <!-- Category -->
        <div class="mb-4">
          <label class="form-label" for="category">
            <i class="bi bi-tag me-1"></i>Category
          </label>
          <select class="form-control" id="category" name="listing[category]">
            <option value="">— Select a category (optional) —</option>
            <option value="trending">🔥 Trending</option>
            <option value="beach">🏖️ Beach</option>
            <option value="mountains">⛰️ Mountains</option>
            <option value="city">🏙️ City</option>
            <option value="cabin">🏚️ Cabins</option>
            <option value="luxury">💎 Luxury</option>
            <option value="countryside">🌿 Countryside</option>
            <option value="arctic">❄️ Arctic</option>
            <option value="camping">⛺ Camping</option>
            <option value="farm">🌻 Farms</option>
            <option value="pool">🏊 Pools</option>
          </select>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary w-100" style="padding:0.9rem;font-size:1rem;">
          <i class="bi bi-plus-circle me-2"></i>Publish Listing
        </button>

      </form>
    </div>

  </div>
</div>

<script>
  function previewImage(input) {
    const preview = document.getElementById('imgPreview');
    const img = document.getElementById('previewEl');
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = e => {
        img.src = e.target.result;
        preview.style.display = 'block';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>

