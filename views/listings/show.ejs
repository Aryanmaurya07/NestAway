        <hr class="divider-gold" style="margin:1rem 0;">

        <!-- Quick details -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.5rem;">
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">🛏️</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Bedrooms</div>
            <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">2</div>
          </div>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">👥</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Guests</div>
            <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">4</div>
          </div>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">🚿</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Bathrooms</div>
            <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">1</div>
          </div>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">📶</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Wi-Fi</div>
            <div style="font-weight:600;font-size:0.9rem;color:#6ee7b7;">Yes</div>
          </div>
        </div>

        <!-- Reserve button -->
        <% if(currentUser) { %>
          <button class="btn btn-primary w-100" style="padding:0.9rem;font-size:1rem;">
            <i class="bi bi-calendar2-check me-2"></i>Reserve Now
          </button>
          <p style="text-align:center;font-size:0.78rem;color:var(--text-muted);margin-top:0.6rem;">You won't be charged yet</p>
        <% } else { %>
          <a href="/login" class="btn btn-primary w-100" style="padding:0.9rem;font-size:1rem;">
            <i class="bi bi-box-arrow-in-right me-2"></i>Sign in to Reserve
          </a>
        <% } %>

        <hr class="divider-gold" style="margin:1.2rem 0;">

        <!-- Edit / Delete (if owner) -->
        <% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex gap-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark flex-fill">
              <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="flex-fill">
              <button type="submit" class="btn w-100"
                      style="background:rgba(251,113,133,0.08);border:1px solid rgba(251,113,133,0.3);color:rgba(251,113,133,0.8);"
                      onclick="return confirm('Delete this listing?')">
                <i class="bi bi-trash3 me-1"></i>Delete
              </button>
            </form>
          </div>
        <% } %>

        <!-- Share -->
        <button class="btn btn-dark w-100 mt-2" onclick="shareListng()" style="font-size:0.85rem;">
          <i class="bi bi-share me-1"></i>Share this stay
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  // Star rating picker
  function setRating(val) {
    document.getElementById('ratingInput').value = val;
    document.querySelectorAll('#starSelector i').forEach((star, idx) => {
      star.className = idx < val ? 'bi bi-star-fill' : 'bi bi-star';
      star.style.color = idx < val ? 'var(--gold)' : 'var(--text-muted)';
    });
  }
  // Init with default 4
  setRating(4);

  // Share
  function shareListng() {
    if (navigator.share) {
      navigator.share({ title: '<%= listing.title %>', url: window.location.href });
    } else {
      navigator.clipboard.writeText(window.location.href);
      alert('Link copied to clipboard!');
    }
  }
</script>
