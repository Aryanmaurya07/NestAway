<% layout("/layouts/boilerplate.ejs") %>

<!-- NestAway — Listing Detail / Show Page -->

<div class="container my-5">
  <div class="row g-5">

    <!-- ─── Left: Listing Details ──────────────────── -->
    <div class="col-lg-7">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="reveal">
        <ol class="breadcrumb" style="font-size:0.82rem;margin-bottom:1rem;">
          <li class="breadcrumb-item"><a href="/listings" style="color:var(--text-muted);">Explore</a></li>
          <% if(listing.location) { %>
            <li class="breadcrumb-item" style="color:var(--text-muted);"><%= listing.location %></li>
          <% } %>
          <li class="breadcrumb-item active" style="color:var(--text-secondary);"><%= listing.title %></li>
        </ol>
      </nav>

      <!-- Main Image -->
      <div class="reveal" style="position:relative;">
        <% if(listing.image && listing.image.url) { %>
          <img src="<%= listing.image.url %>"
               class="listing-show-img"
               alt="<%= listing.title %>"
               onerror="this.src='https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=900&q=80'">
        <% } else { %>
          <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=900&q=80"
               class="listing-show-img" alt="<%= listing.title %>">
        <% } %>

        <!-- Badges over image -->
        <div style="position:absolute;bottom:16px;left:16px;display:flex;gap:0.5rem;flex-wrap:wrap;">
          <span class="listing-badge"><i class="bi bi-star-fill me-1"></i>4.8</span>
          <% if(listing.country) { %>
            <span class="listing-badge"><i class="bi bi-geo-alt me-1"></i><%= listing.country %></span>
          <% } %>
        </div>
      </div>

      <!-- Title & Host -->
      <div class="reveal">
        <h1 class="listing-show-title mt-4"><%= listing.title %></h1>
        <% if(listing.location) { %>
          <p style="color:var(--text-secondary);font-size:0.95rem;margin-bottom:1rem;">
            <i class="bi bi-geo-alt-fill me-1" style="color:var(--gold);"></i>
            <%= listing.location %><% if(listing.country) { %>, <%= listing.country %><% } %>
          </p>
        <% } %>

        <!-- Host info -->
        <% if(listing.owner) { %>
          <div style="display:flex;align-items:center;gap:0.75rem;padding:1rem;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);margin-bottom:1.5rem;">
            <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-light));display:flex;align-items:center;justify-content:center;color:#0a0a12;font-weight:700;font-size:1rem;font-family:'Sora',sans-serif;flex-shrink:0;">
              <%= listing.owner.username ? listing.owner.username[0].toUpperCase() : 'H' %>
            </div>
            <div>
              <div style="font-family:'Sora',sans-serif;font-weight:600;font-size:0.9rem;color:var(--text-primary);">
                Hosted by <%= listing.owner.username %>
              </div>
              <div style="font-size:0.8rem;color:var(--text-muted);">Verified Host &nbsp;·&nbsp; Member since 2023</div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Description -->
      <% if(listing.description) { %>
        <div class="reveal" style="margin-bottom:1.5rem;">
          <p class="section-label">About this place</p>
          <p style="color:var(--text-secondary);line-height:1.8;"><%= listing.description %></p>
        </div>
      <% } %>

      <hr class="divider-gold">

      <!-- Map -->
      <div class="reveal" style="margin-bottom:2rem;">
        <p class="section-label">Location</p>
        <h3 class="section-title" style="font-size:1.2rem;margin-bottom:1rem;">
          Where you'll be
        </h3>
        <div id="map" style="height:300px;"></div>
      </div>

      <hr class="divider-gold">

      <!-- Reviews Section -->
      <div class="reveal" style="margin-bottom:2rem;">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div>
            <p class="section-label">Guest Feedback</p>
            <h3 class="section-title" style="font-size:1.3rem;">Reviews</h3>
          </div>
          <% if(listing.reviews && listing.reviews.length) { %>
            <span class="listing-badge">
              <i class="bi bi-star-fill me-1"></i>
              <%= (listing.reviews.reduce((a, r) => a + (r.rating || 4), 0) / listing.reviews.length).toFixed(1) %>
              &nbsp;(<%= listing.reviews.length %>)
            </span>
          <% } %>
        </div>

        <!-- Leave a Review (if logged in) -->
        <% if(currentUser) { %>
          <div class="form-wrapper reveal" style="max-width:100%;margin:0 0 1.5rem;">
            <h5 style="font-family:'Sora',sans-serif;font-weight:600;font-size:1rem;margin-bottom:1rem;color:var(--text-primary);">
              Share your experience
            </h5>
            <form method="POST" action="/listings/<%= listing._id %>/reviews">
              <div class="mb-3">
                <label class="form-label">Rating</label>
                <div class="star-selector" style="display:flex;gap:0.4rem;margin-bottom:0.5rem;" id="starSelector">
                  <% for(let i=1;i<=5;i++) { %>
                    <i class="bi bi-star" data-val="<%= i %>"
                       style="font-size:1.5rem;cursor:pointer;color:var(--text-muted);transition:color 0.2s;"
                       onclick="setRating(<%= i %>)"></i>
                  <% } %>
                </div>
                <input type="hidden" name="review[rating]" id="ratingInput" value="4">
              </div>
              <div class="mb-3">
                <label class="form-label">Your Review</label>
                <textarea class="form-control" name="review[comment]" rows="3"
                          placeholder="What did you love about this place?" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-send me-1"></i>Post Review
              </button>
            </form>
          </div>
        <% } else { %>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);padding:1.2rem;text-align:center;margin-bottom:1.5rem;">
            <p style="color:var(--text-muted);font-size:0.9rem;margin:0;">
              <a href="/login">Sign in</a> to leave a review.
            </p>
          </div>
        <% } %>

        <!-- Existing reviews -->
        <div class="row g-3 reveal-stagger">
          <% if(listing.reviews && listing.reviews.length > 0) { %>
            <% for(let review of listing.reviews) { %>
              <div class="col-12">
                <div class="review-card">
                  <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="d-flex align-items-center gap-2">
                      <div style="width:32px;height:32px;border-radius:50%;background:var(--violet-dim);border:1px solid rgba(139,92,246,0.3);display:flex;align-items:center;justify-content:center;color:var(--violet);font-weight:700;font-size:0.8rem;font-family:'Sora',sans-serif;">
                        <%= review.author ? review.author.username[0].toUpperCase() : 'G' %>
                      </div>
                      <div>
                        <div class="review-author"><%= review.author ? review.author.username : 'Guest' %></div>
                        <div class="stars" style="font-size:0.75rem;">
                          <% for(let i=0;i<(review.rating||4);i++) { %>★<% } %>
                        </div>
                      </div>
                    </div>
                    <!-- Delete review (if owner) -->
                    <% if(currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                      <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button type="submit" class="btn btn-sm"
                                style="background:transparent;border:1px solid rgba(251,113,133,0.3);color:rgba(251,113,133,0.7);border-radius:var(--radius-sm);padding:0.25rem 0.6rem;font-size:0.75rem;transition:all 0.2s;"
                                onmouseover="this.style.borderColor='rgba(251,113,133,0.8)';this.style.color='rgba(251,113,133,1)';"
                                onmouseout="this.style.borderColor='rgba(251,113,133,0.3)';this.style.color='rgba(251,113,133,0.7)';">
                          <i class="bi bi-trash3"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                  <p class="review-body"><%= review.comment %></p>
                </div>
              </div>
            <% } %>
          <% } else { %>
            <div class="col-12">
              <p style="color:var(--text-muted);font-size:0.9rem;padding:1rem 0;">No reviews yet. Be the first to share your experience!</p>
            </div>
          <% } %>
        </div>
      </div>

    </div>

    <!-- ─── Right: Booking Card ────────────────────── -->
    <div class="col-lg-5">
      <div class="listing-detail-card reveal">

        <!-- Price -->
        <div class="d-flex align-items-baseline gap-2 mb-1">
          <span style="font-family:'Sora',sans-serif;font-size:1.9rem;font-weight:800;color:var(--gold);">
            ₹<%= listing.price ? listing.price.toLocaleString('en-IN') : '—' %>
          </span>
          <span style="color:var(--text-muted);font-size:0.9rem;">per night</span>
        </div>
        <div class="stars mb-3">★★★★<span style="opacity:0.4;">★</span>
          <span style="color:var(--text-muted);font-size:0.8rem;margin-left:4px;">
            (<%= listing.reviews ? listing.reviews.length : 0 %> reviews)
          </span>
        </div>

        <hr class="divider-gold" style="margin:1rem 0;">

        <!-- Quick details -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.5rem;">
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">🛏️</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Bedrooms</div>
            <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">2</div>
          </div>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">👥</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Guests</div>
            <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">4</div>
          </div>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">🚿</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Bathrooms</div>
            <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">1</div>
          </div>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.8rem;text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:0.2rem;">📶</div>
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;color:var(--text-muted);">Wi-Fi</div>
            <div style="font-weight:600;font-size:0.9rem;color:#6ee7b7;">Yes</div>
          </div>
        </div>

        <!-- Reserve button -->
        <% if(currentUser) { %>
          <button class="btn btn-primary w-100" style="padding:0.9rem;font-size:1rem;">
            <i class="bi bi-calendar2-check me-2"></i>Reserve Now
          </button>
          <p style="text-align:center;font-size:0.78rem;color:var(--text-muted);margin-top:0.6rem;">You won't be charged yet</p>
        <% } else { %>
          <a href="/login" class="btn btn-primary w-100" style="padding:0.9rem;font-size:1rem;">
            <i class="bi bi-box-arrow-in-right me-2"></i>Sign in to Reserve
          </a>
        <% } %>

        <hr class="divider-gold" style="margin:1.2rem 0;">

        <!-- Edit / Delete (if owner) -->
        <% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex gap-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark flex-fill">
              <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="flex-fill">
              <button type="submit" class="btn w-100"
                      style="background:rgba(251,113,133,0.08);border:1px solid rgba(251,113,133,0.3);color:rgba(251,113,133,0.8);"
                      onclick="return confirm('Delete this listing?')">
                <i class="bi bi-trash3 me-1"></i>Delete
              </button>
            </form>
          </div>
        <% } %>

        <!-- Share -->
        <button class="btn btn-dark w-100 mt-2" onclick="shareListng()" style="font-size:0.85rem;">
          <i class="bi bi-share me-1"></i>Share this stay
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  // Star rating picker
  function setRating(val) {
    document.getElementById('ratingInput').value = val;
    document.querySelectorAll('#starSelector i').forEach((star, idx) => {
      star.className = idx < val ? 'bi bi-star-fill' : 'bi bi-star';
      star.style.color = idx < val ? 'var(--gold)' : 'var(--text-muted)';
    });
  }
  // Init with default 4
  setRating(4);

  // Share
  function shareListng() {
    if (navigator.share) {
      navigator.share({ title: '<%= listing.title %>', url: window.location.href });
    } else {
      navigator.clipboard.writeText(window.location.href);
      alert('Link copied to clipboard!');
    }
  }
</script>
