<% layout("/layouts/boilerplate.ejs") %>

<!-- ─── Hero Section ─────────────────────────────────── -->
<section class="nestaway-hero">
  <div class="container">
    <p class="section-label reveal">✦ Premium Stays Worldwide</p>
    <h1 class="hero-headline reveal">Find where<br>you truly belong.</h1>
    <p class="hero-subline reveal">
      Discover handpicked homes, cabins, villas, and unique stays — curated for the discerning traveller.
    </p>
    <form class="search-bar reveal" action="/listings/search" method="get">
      <i class="bi bi-search" style="color:var(--text-muted);"></i>
      <input type="text" name="q" id="heroSearch" placeholder="Destination, city, or property name…" autocomplete="off">
      <button class="search-btn" type="submit">
        <i class="bi bi-search me-1"></i>Search
      </button>
    </form>
    <div class="stats-row reveal">
      <div class="stat-item"><div class="stat-number">2.4K+</div><div class="stat-label">Listings</div></div>
      <div class="stat-item"><div class="stat-number">140+</div><div class="stat-label">Countries</div></div>
      <div class="stat-item"><div class="stat-number">98%</div><div class="stat-label">Satisfaction</div></div>
    </div>
  </div>
</section>

<!-- ─── Filter Pills with Scroll Arrows ─────────────── -->
<div class="container py-4">
  <div class="filter-scroll-wrapper">
    <!-- Left scroll button -->
    <button class="filter-scroll-btn" id="scrollLeft" onclick="scrollFilters(-1)" title="Scroll left">
      <i class="bi bi-chevron-left"></i>
    </button>

    <!-- Filter pills row -->
    <div class="filter-row" id="filterRow">
      <button class="filter-pill active" onclick="filterCategory(this,'all')">
        <i class="bi bi-grid-fill"></i> All Stays
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'trending')">
        <i class="bi bi-fire"></i> Trending
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'beach')">
        <i class="bi bi-umbrella-fill"></i> Beach
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'mountains')">
        <i class="bi bi-triangle"></i> Mountains
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'city')">
        <i class="bi bi-buildings"></i> City
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'cabin')">
        <i class="bi bi-house-heart"></i> Cabins
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'luxury')">
        <i class="bi bi-gem"></i> Luxury
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'countryside')">
        <i class="bi bi-tree"></i> Countryside
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'arctic')">
        <i class="bi bi-snow"></i> Arctic
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'camping')">
        <i class="bi bi-cup-hot"></i> Camping
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'farm')">
        <i class="bi bi-flower1"></i> Farms
      </button>
      <button class="filter-pill" onclick="filterCategory(this,'pool')">
        <i class="bi bi-water"></i> Pools
      </button>
    </div>

    <!-- Right scroll button -->
    <button class="filter-scroll-btn" id="scrollRight" onclick="scrollFilters(1)" title="Scroll right">
      <i class="bi bi-chevron-right"></i>
    </button>
  </div>
</div>

<!-- ─── Listings Grid ────────────────────────────────── -->
<div class="container pb-5">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <p class="section-label">Our Collection</p>
      <h2 class="section-title">Available Stays</h2>
    </div>
    <span style="color:var(--text-muted);font-family:'Sora',sans-serif;font-size:0.85rem;">
      <span id="visibleCount"><%= allListings.length %></span> properties
    </span>
  </div>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 reveal-stagger" id="listingsGrid">
    <% for(let listing of allListings) { %>
      <div class="col listing-col"
           data-title="<%= listing.title.toLowerCase() %>"
           data-location="<%= listing.location ? listing.location.toLowerCase() : '' %>"
           data-category="<%= listing.category ? listing.category.toLowerCase() : '' %>">
        <a href="/listings/<%= listing._id %>" class="text-decoration-none">
          <div class="card h-100">
            <div class="listing-img-wrapper">
              <% if(listing.image && listing.image.url) { %>
                <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>"
                     loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=600&q=80'">
              <% } else { %>
                <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=600&q=80"
                     class="card-img-top" alt="<%= listing.title %>" loading="lazy">
              <% } %>
              <div class="img-overlay"></div>
              <button class="wishlist-btn" onclick="event.preventDefault();toggleWishlist(this)" title="Save">
                <i class="bi bi-heart"></i>
              </button>
            </div>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= listing.title %></h5>
              <% if(listing.location) { %>
                <p class="card-text" style="font-size:0.82rem;color:var(--text-muted);margin-bottom:0.5rem;">
                  <i class="bi bi-geo-alt me-1" style="color:var(--gold);"></i>
                  <%= listing.location %><% if(listing.country) { %>, <%= listing.country %><% } %>
                </p>
              <% } %>
              <div class="mt-auto pt-2 d-flex align-items-center justify-content-between"
                   style="border-top:1px solid var(--border);">
                <div class="listing-price">
                  ₹<%= listing.price ? listing.price.toLocaleString('en-IN') : '—' %>
                  <span>/ night</span>
                </div>
                <div class="stars">★★★★<span style="opacity:0.4;">★</span></div>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <!-- Empty state -->
  <div id="emptyState" style="display:none;text-align:center;padding:4rem 1rem;">
    <div style="font-size:3rem;margin-bottom:1rem;">🔍</div>
    <h4 style="color:var(--text-secondary);font-family:'Sora',sans-serif;">No stays found</h4>
    <p style="color:var(--text-muted);">Try a different filter or explore all stays.</p>
    <button class="btn btn-outline-primary mt-2" onclick="resetCategory()">Show all stays</button>
  </div>
</div>

<style>
  .wishlist-btn {
    position:absolute;top:12px;right:12px;
    background:rgba(8,8,15,0.55);border:1px solid rgba(255,255,255,0.12);
    border-radius:50%;width:34px;height:34px;
    display:flex;align-items:center;justify-content:center;
    cursor:pointer;transition:all .3s ease;
    backdrop-filter:blur(8px);color:var(--text-secondary);font-size:.9rem;
  }
  .wishlist-btn:hover,.wishlist-btn.saved {
    background:rgba(51,195,117,.2)!important;
    border-color:rgba(51,195,117,.5)!important;color:var(--gold)!important;
  }
  .wishlist-btn.saved i { font-weight:900; }
</style>

<script>
  // ── Filter state ─────────────────────────────────────
  let activeCategory = 'all';

  function filterCategory(btn, cat) {
    activeCategory = cat;
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');

    const grid = document.getElementById('listingsGrid');
    grid.style.opacity = '0';
    grid.style.transform = 'translateY(10px)';

    setTimeout(() => {
      let count = 0;
      document.querySelectorAll('.listing-col').forEach(col => {
        const colCat = (col.dataset.category || '').toLowerCase();
        const show = cat === 'all' || colCat === cat || colCat.includes(cat);
        col.style.display = show ? '' : 'none';
        if (show) count++;
      });

      const countEl = document.getElementById('visibleCount');
      if (countEl) countEl.textContent = count;
      document.getElementById('emptyState').style.display = count === 0 ? 'block' : 'none';

      grid.style.transition = 'opacity .35s ease,transform .35s ease';
      grid.style.opacity = '1';
      grid.style.transform = 'translateY(0)';
    }, 200);
  }

  function resetCategory() {
    activeCategory = 'all';
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    document.querySelector('.filter-pill').classList.add('active');
    document.querySelectorAll('.listing-col').forEach(c => c.style.display = '');
    document.getElementById('emptyState').style.display = 'none';
    const countEl = document.getElementById('visibleCount');
    if (countEl) countEl.textContent = document.querySelectorAll('.listing-col').length;
  }

  // ── Wishlist ─────────────────────────────────────────
  function toggleWishlist(btn) {
    btn.classList.toggle('saved');
    btn.querySelector('i').className = btn.classList.contains('saved') ? 'bi bi-heart-fill' : 'bi bi-heart';
  }

  // ── Filter row scroll arrows ─────────────────────────
  function scrollFilters(dir) {
    const row = document.getElementById('filterRow');
    row.scrollBy({ left: dir * 220, behavior: 'smooth' });
    setTimeout(updateScrollBtns, 300);
  }

  function updateScrollBtns() {
    const row = document.getElementById('filterRow');
    const leftBtn = document.getElementById('scrollLeft');
    const rightBtn = document.getElementById('scrollRight');
    if (!row || !leftBtn || !rightBtn) return;
    leftBtn.disabled = row.scrollLeft <= 0;
    rightBtn.disabled = row.scrollLeft >= row.scrollWidth - row.clientWidth - 2;
  }

  document.addEventListener('DOMContentLoaded', function() {
    const row = document.getElementById('filterRow');
    if (row) {
      row.addEventListener('scroll', updateScrollBtns);
      updateScrollBtns();
    }
  });
</script>
